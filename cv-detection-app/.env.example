# Ollama service
OLLAMA_HOST=http://10.0.0.192:11434
OLLAMA_MODEL_IMAGE=llava:13b
OLLAMA_MODEL_WEBCAM=moondream
OLLAMA_TIMEOUT_SECONDS=30

# YOLO local detection
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.45
YOLO_MAX_PERSONS=10

# Distance estimation
DEPTH_MODEL=MiDaS_small
DEPTH_ENABLED=true
DEPTH_SCALE=1.0

# Application server
APP_HOST=0.0.0.0
APP_PORT_PREFERRED=8080
APP_PORT_FALLBACK_RANGE=8081,8090
APP_SECRET_KEY=changeme_replace_in_prod

# Webcam
WEBCAM_INDEX=0
WEBCAM_FRAME_WIDTH=1280
WEBCAM_FRAME_HEIGHT=720
WEBCAM_TARGET_FPS=15

# LAN awareness
LAN_LATENCY_WARN_MS=50
LAN_RETRY_ATTEMPTS=3
LAN_RETRY_DELAY_MS=500

# Logging
LOG_LEVEL=INFO
